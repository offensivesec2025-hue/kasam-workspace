# Kasam Workspace Environment Configuration
# Copy this file to .env and customize settings as needed
# Note: GitHub Codespaces provides authentication; these defaults are acceptable

# ===========================
# VNC Server Configuration
# ===========================

# VNC Server Password
# Default is acceptable for Codespaces (GitHub authentication provides security layer)
VNC_PW=codespaces

# Desktop Resolution (WIDTHxHEIGHT)
# Supported values: 1024x768, 1280x1024, 1920x1080, 2560x1440
RESOLUTION=1920x1080

# VNC Quality Setting (1-100)
# Higher values = better quality but more bandwidth
VNC_QUALITY=80

# VNC Compression Level (0-9)
# Higher values = more compression but more CPU usage
VNC_COMPRESSION=6

# ===========================
# Container User Configuration
# ===========================

# Process User ID (must match Linux UID)
# Default 1000 is standard for first non-root user
PUID=1000

# Process Group ID (must match Linux GID)
# Default 1000 is standard for first non-root group
PGID=1000

# ===========================
# Inactivity Monitor Settings
# ===========================

# Idle Timeout Duration (in seconds)
# 900 seconds = 15 minutes (recommended for Codespaces)
# Increase to 1800 for 30 minutes, 3600 for 60 minutes
IDLE_TIMEOUT=900

# Warning Display Time Before Shutdown (in seconds)
# User has this many seconds to move mouse/press key to prevent shutdown
WARNING_TIME=60

# Activity Monitor Check Interval (in seconds)
# How often to check for activity (lower = more responsive, higher = less CPU)
# Default 30 seconds is optimal balance
CHECK_INTERVAL=30

# ===========================
# Logging Configuration
# ===========================

# Activity Log File Path
# Inactivity monitor logs all activity checks here
ACTIVITY_LOG_FILE=/tmp/kasam-idle.log

# Log Level (DEBUG, INFO, WARNING, ERROR)
# DEBUG = very verbose, ERROR = minimal logging
LOG_LEVEL=INFO

# Enable Activity Log Compression
# Automatically gzip logs when they exceed 10MB
LOG_COMPRESSION=true

# ===========================
# Memory and Performance
# ===========================

# Shared Memory Size (for X11/VNC streaming)
# Minimum: 256m, Recommended: 512m, Maximum: 1g
# Higher values improve streaming performance for large resolutions
SHM_SIZE=512m

# Enable GPU Acceleration (if available)
# Set to "true" if GPU is available for video encoding
GPU_ACCELERATION=false

# ===========================
# Application Installation
# ===========================

# Additional Tools to Install (comma-separated)
# Examples: metasploit-framework, nikto, aircrack-ng, burp, etc.
ADDITIONAL_TOOLS=""

# Install Development Tools (GCC, Make, Node.js, Python, etc.)
INSTALL_DEV_TOOLS=false

# ===========================
# Desktop Environment Settings
# ===========================

# Desktop Theme (ubuntu, xfce, kde, gnome)
DESKTOP_THEME=ubuntu

# Keyboard Layout (us, uk, de, fr, jp, etc.)
KEYBOARD_LAYOUT=us

# Timezone (e.g., UTC, America/New_York, Europe/London)
TIMEZONE=UTC

# Enable Auto-login (true/false)
# Auto-logs in kasm_user on startup
AUTO_LOGIN=true

# ===========================
# Network Configuration
# ===========================

# VNC Port (usually 6901 for Codespaces)
VNC_PORT=6901

# Allow Remote Connections (true/false)
ALLOW_REMOTE=true

# ===========================
# Security Settings
# ===========================

# Enable Two-Factor Authentication for VNC
# GitHub Codespaces provides authentication layer
VNC_2FA=false

# Enable SSL/TLS for VNC Connection
# Codespaces handles HTTPS; set to false
VNC_SSL=false

# Enforce VNC Password on Every Connection
VNC_PASSWORD_REQUIRED=true

# ===========================
# Debugging and Troubleshooting
# ===========================

# Enable Debug Mode (verbose logging)
DEBUG_MODE=false

# Keep Container Running After Idle Shutdown Test
KEEP_CONTAINER_AFTER_SHUTDOWN=false

# Simulate Idle Timeout for Testing (in seconds)
# Set to a low value (e.g., 60) to test shutdown quickly
# Leave empty or 0 to use normal IDLE_TIMEOUT
TEST_IDLE_TIMEOUT=0

# ===========================
# Notes for GitHub Codespaces
# ===========================
#
# 1. GitHub Codespaces provides built-in authentication
#    These environment variables are for container internals only
#
# 2. VNC Password is transmitted over HTTPS (via Codespaces forwarding)
#    No need to change default 'codespaces' password
#
# 3. Port 6901 (KasmVNC) is automatically forwarded
#    Access at: https://<codespace>.preview.app.github.dev:6901
#
# 4. Auto-shutdown after 15 minutes saves compute hours
#    You can adjust IDLE_TIMEOUT to fit your workflow
#
# 5. All settings are optional; defaults work well for most users
#    Only change if you understand the implications
#
# 6. Changes require container rebuild: F1 > Rebuild Container
#
